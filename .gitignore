# Dependencies
node_modules/
.pnpm-store/

# Build outputs
.next/
# Next regenerates next-env.d.ts on build (adds a typed-routes import that
# points into .next), so it's generated, not committed.
next-env.d.ts
out/
dist/
build/
.turbo/
*.tsbuildinfo

# Expo / React Native
.expo/
.expo-shared/
# Native projects are generated via `expo prebuild` / EAS — never commit them.
/apps/mobile/ios/
/apps/mobile/android/
*.orig.*
web-build/

# Secrets / env — commit ONLY .env.example
.env
.env.*
!.env.example
*.local

# MCP server config may contain an access token — never commit it.
.mcp.json

# Supabase CLI local artifacts
/supabase/.branches/
/supabase/.temp/

# Logs / OS / editor
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.DS_Store
Thumbs.db
.idea/
.vscode/*
!.vscode/extensions.json

# Claude Code local (machine-specific) settings
.claude/settings.local.json

# Test / coverage
coverage/
