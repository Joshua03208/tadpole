# Tadpole monorepo — pnpm settings
#
# node-linker=hoisted gives a flat node_modules (npm-style). This is the
# pragmatic, documented fix for two things on this stack:
#   1. @supabase/ssr throwing "Module not found" under Next.js with pnpm's
#      default isolated store.
#   2. React Native / Metro being unable to resolve hoisted peer deps.
# See docs/TADPOLE_PLAN.md §2 and the Phase 0 notes.
node-linker=hoisted

# Don't fail installs on peer-dep mismatches (Expo/RN pin many transitive
# peers; we validate the real graph with `expo install --fix` + `expo-doctor`).
auto-install-peers=true
strict-peer-dependencies=false

# Keep the store deterministic with the pinned packageManager version.
prefer-frozen-lockfile=false
