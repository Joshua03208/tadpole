# ============================================================================
# Tadpole — environment variable surface (TEMPLATE ONLY — no real secrets here)
# ----------------------------------------------------------------------------
# Copy to `.env.local` (web) and supply real values. `.env*` is gitignored;
# ONLY this .env.example is committed. NEVER paste a real key into this file.
#
# Key rules (CLAUDE.md non-negotiables):
#   • The service_role key is SERVER-ONLY. Never in apps/mobile, never in any
#     client bundle, never committed.
#   • Web exposes only NEXT_PUBLIC_* to the browser; mobile exposes only
#     EXPO_PUBLIC_* to the device runtime.
# ============================================================================

# ---- Supabase (UK/EU project) ----------------------------------------------
# Public (safe in client bundles): the project URL + the anon/publishable key.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Mobile reads its own EXPO_PUBLIC_* copies (surfaced via app.config.ts `extra`).
EXPO_PUBLIC_SUPABASE_URL=
EXPO_PUBLIC_SUPABASE_ANON_KEY=

# SERVER ONLY — used by Next.js route handlers / server actions / Edge Functions.
# Bypasses ALL row-level security. Must NEVER reach apps/mobile or the browser.
SUPABASE_SERVICE_ROLE_KEY=

# Used by tooling only (type generation in Phase 1): the project ref, e.g. abcd1234.
SUPABASE_PROJECT_ID=

# ---- Later phases (kept here so the full env surface is documented) ---------
# Phase 4+ — product analytics (PostHog EU Cloud) + cookieless web analytics (Umami).
# NEXT_PUBLIC_POSTHOG_KEY=
# NEXT_PUBLIC_POSTHOG_HOST=https://eu.i.posthog.com
# NEXT_PUBLIC_UMAMI_WEBSITE_ID=
# NEXT_PUBLIC_UMAMI_SRC=

# Phase 0+ — error tracking (Sentry). DSN is publishable; auth token is CI-only.
# NEXT_PUBLIC_SENTRY_DSN=
# SENTRY_AUTH_TOKEN=

# Phase 6 — payments (Stripe). Secret + webhook secret are SERVER ONLY.
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=
