{
  "$schema": "https://json.schemastore.org/tsconfig",
  "display": "@tadpole/config — Next.js (App Router)",
  "extends": "./base.json",
  "compilerOptions": {
    "lib": ["DOM", "DOM.Iterable", "ES2023"],
    "jsx": "preserve",
    "allowJs": true,
    "incremental": true,
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "plugins": [{ "name": "next" }]
  }
}
